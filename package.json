{
  "name": "apcore-toolkit",
  "version": "0.4.0",
  "description": "Shared scanner, schema extraction, and output toolkit for apcore framework adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": {
    "name": "aiperceivable",
    "email": "tercel.yi@gmail.com"
  },
  "keywords": [
    "apcore",
    "mcp",
    "scanner",
    "schema",
    "yaml",
    "openapi",
    "toolkit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aiperceivable/apcore-toolkit-typescript"
  },
  "homepage": "https://aiperceivable.com",
  "bugs": {
    "url": "https://github.com/aiperceivable/apcore-toolkit-typescript/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "apcore-js": ">=0.14.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "apdev-js": "^0.2.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "apdev": {
    "base_package": "apcore-toolkit"
  }
}